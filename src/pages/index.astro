<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Contemporary oil paintings exploring memory, season, and quiet observation through birds."
    />
    <title>Wil Vark | Contemporary Oil Paintings</title>
  </head>

  <body>
    <main class="home">
      <section class="intro" aria-labelledby="site-title">
        <p class="eyebrow">Contemporary Oil Paintings</p>

        <h1 id="site-title">Wil Vark</h1>

        <p class="statement">
          Exploring memory through birds,<br />
          seasons, and silence.
        </p>

        <a href="/gallery" class="enter-link">Enter Gallery</a>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --color-ground: #f7f4ef;
    --color-text: #1f1f1d;
    --color-muted: #6f6a61;
    --color-line: #ded8cf;
  }

  html {
    background: var(--color-ground);
    color: var(--color-text);
    font-family: Georgia, 'Times New Roman', serif;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  .home {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 3rem 1.5rem 8rem;
  }

  .intro {
    max-width: 42rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 2.75rem;
    color: var(--color-muted);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.25rem, 8vw, 6.75rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .statement {
    margin: 2.75rem 0 4rem;
    color: var(--color-muted);
    font-size: clamp(1.3rem, 2.7vw, 1.95rem);
    font-weight: 400;
    line-height: 1.45;
  }

  .enter-link {
    display: inline-block;
    color: var(--color-text);
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 0.45rem;
    transition:
      color 160ms ease,
      border-color 160ms ease;
  }

  .enter-link:hover,
  .enter-link:focus-visible {
    color: var(--color-muted);
    border-color: var(--color-muted);
  }
</style>