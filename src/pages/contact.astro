---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="Contact | Wil Vark"
  description="Contact Wil Vark about paintings, exhibitions, or available works."
>
  <main class="page">
    <SiteHeader />

    <article class="prose">
      <h1>Contact</h1>

      <p>
        For questions about paintings, available works, or exhibitions, please email:
      </p>

      <p class="email">
        <a href="mailto:wilvark@gmail.com">wilvark@gmail.com</a>
      </p>
    </article>
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 78rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 8rem;
  }

  .prose {
    max-width: 38rem;
  }

  h1 {
    margin: 0 0 3rem;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .prose p {
    margin: 0 0 1.75rem;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .email {
    margin-top: 2.5rem;
  }

  .email a {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 0.25rem;
  }

  .email a:hover,
  .email a:focus-visible {
    color: var(--color-muted);
    border-color: var(--color-muted);
  }
</style>
