---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

export async function getStaticPaths() {
  const paintings = await getCollection('paintings');

  const sorted = paintings.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((painting, index) => ({
    params: { slug: painting.id },
    props: {
      painting,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { painting, prev, next } = Astro.props;
const { Content } = await render(painting);

const artworkSchema = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: painting.data.title,
  url: new URL(`/paintings/${painting.id}`, Astro.site).href,
  image: new URL(painting.data.image.src, Astro.site).href,
  artform: 'Painting',
  artMedium: painting.data.medium,
  ...(() => {
    // size frontmatter reads height × width, e.g. "9 × 12 in"
    const m = painting.data.size.match(/([\d.]+)\s*×\s*([\d.]+)/);
    return m
      ? {
          height: { '@type': 'Distance', name: `${m[1]} inches` },
          width: { '@type': 'Distance', name: `${m[2]} inches` },
        }
      : {};
  })(),
  dateCreated: String(painting.data.year),
  creator: {
    '@type': 'Person',
    name: 'Wil Vark',
    url: 'https://wilvark.com/about',
  },
  ...(painting.data.series && { isPartOf: { '@type': 'CreativeWorkSeries', name: painting.data.series } }),
};
---

<BaseLayout
  title={`${painting.data.title} | Wil Vark`}
  description={`${painting.data.title} — ${painting.data.medium}, ${painting.data.size}, ${painting.data.year}. By Wil Vark.`}
  ogImage={painting.data.image}
  ogType="article"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(artworkSchema)}
  />

  <main class="painting-page">
    <SiteHeader />

    <article>
      <header class="painting-header">
        {painting.data.series && <p class="series">{painting.data.series}</p>}
        <h1>{painting.data.title}</h1>
      </header>

      <figure class="painting-image">
        <Image
          src={painting.data.image}
          alt={painting.data.imageAlt}
          widths={[640, 1024, 1440, 2048]}
          sizes="(max-width: 1312px) calc(100vw - 3rem), 1248px"
          loading="eager"
          fetchpriority="high"
        />
      </figure>

      <div class="painting-details">
        <div class="meta">
          <p>{painting.data.medium}</p>
          <p>{painting.data.size}</p>
          <p>{painting.data.year}</p>
        </div>

        <div class="statement">
          <Content />
        </div>
      </div>
    </article>

    <nav class="painting-nav" aria-label="More paintings">
      {
        prev ? (
          <a href={`/paintings/${prev.id}`} rel="prev" class="nav-prev">
            <span class="nav-label">Previous</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next && (
          <a href={`/paintings/${next.id}`} rel="next" class="nav-next">
            <span class="nav-label">Next</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        )
      }
    </nav>
  </main>
</BaseLayout>

<style>
  .painting-page {
    max-width: 78rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 8rem;
  }

  .painting-header {
    max-width: 48rem;
    margin-bottom: 4rem;
  }

  .series {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .painting-image {
    margin: 0;
  }

  .painting-image img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 86vh;
    object-fit: contain;
  }

  .painting-details {
    display: grid;
    gap: 3rem;
    max-width: 54rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-line);
  }

  .meta {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .meta p {
    margin: 0;
  }

  .statement {
    color: var(--color-text);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.6;
  }

  .statement :global(p) {
    margin: 0;
  }

  .painting-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 6rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-line);
  }

  .painting-nav a {
    display: grid;
    gap: 0.75rem;
    text-decoration: none;
    max-width: 45%;
  }

  .nav-next {
    text-align: right;
  }

  .nav-label {
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .nav-title {
    color: var(--color-text);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.3;
  }

  .painting-nav a:hover .nav-title,
  .painting-nav a:focus-visible .nav-title {
    color: var(--color-muted);
  }

  @media (min-width: 820px) {
    .painting-page {
      padding-top: 4rem;
    }

    .painting-details {
      grid-template-columns: 14rem 1fr;
      align-items: start;
    }
  }
</style>
