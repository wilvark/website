---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const paintings = await getCollection('paintings');

  return paintings.map((painting) => ({
    params: { slug: painting.id },
    props: { painting },
  }));
}

const { painting } = Astro.props;
const { Content } = await render(painting);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${painting.data.title} by Wil Vark.`} />
    <title>{painting.data.title} | Wil Vark</title>
  </head>

  <body>
    <main class="painting-page">
      <nav class="page-nav" aria-label="Painting navigation">
        <a href="/gallery">Gallery</a>
      </nav>

      <article>
        <header class="painting-header">
          {painting.data.series && <p class="series">{painting.data.series}</p>}
          <h1>{painting.data.title}</h1>
        </header>

        <figure class="painting-image">
          <img src={painting.data.image} alt={painting.data.imageAlt} />
        </figure>

        <div class="painting-details">
          <div class="meta">
            <p>{painting.data.medium}</p>
            <p>{painting.data.size}</p>
            <p>{painting.data.year}</p>
          </div>

          <div class="statement">
            <Content />
          </div>
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    --color-ground: #f7f4ef;
    --color-text: #1f1f1d;
    --color-muted: #6f6a61;
    --color-line: #ded8cf;
  }

  html {
    background: var(--color-ground);
    color: var(--color-text);
    font-family: Georgia, 'Times New Roman', serif;
  }

  body {
    margin: 0;
  }

  .painting-page {
    max-width: 78rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 8rem;
  }

  .page-nav {
    margin-bottom: 6rem;
  }

  .page-nav a {
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .page-nav a:hover,
  .page-nav a:focus-visible {
    color: var(--color-text);
  }

  .painting-header {
    max-width: 48rem;
    margin-bottom: 4rem;
  }

  .series {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }

  .painting-image {
    margin: 0;
  }

  .painting-image img {
    display: block;
    width: 100%;
    max-height: 86vh;
    object-fit: contain;
    background: #eee9e1;
  }

  .painting-details {
    display: grid;
    gap: 3rem;
    max-width: 54rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-line);
  }

  .meta {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .meta p {
    margin: 0;
  }

  .statement {
    color: var(--color-text);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.6;
  }

  .statement :global(p) {
    margin: 0;
  }

  @media (min-width: 820px) {
    .painting-page {
      padding-top: 4rem;
    }

    .painting-details {
      grid-template-columns: 14rem 1fr;
      align-items: start;
    }
  }
</style>
